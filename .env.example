# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tt_mail_db
DATABASE_URL=postgresql://user:password@postgres:5432/tt_mail_db

# Redis
REDIS_URL=redis://redis:6379

# Backend service URLs inside Docker Compose
AGENT1_URL=http://agent1:8001
AGENT2_URL=http://agent2:8002

# Agent 1 / Ollama
# Keep Ollama installed locally on the host. Containers reach it through host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_NUM_PREDICT=256
MAX_EMAILS=10
LOG_LEVEL=INFO

# Gmail OAuth values: keep real values only in local .env or provider secret storage.
CLIENT_ID=
CLIENT_SECRET=
